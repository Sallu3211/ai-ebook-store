# Paddle Billing Configuration
# Get these from your Paddle dashboard at paddle.com

# Your Paddle client-side token (Developer Tools > Authentication)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here

# Product price IDs — one per pricing tier (Catalog > Prices in Paddle dashboard)
NEXT_PUBLIC_PADDLE_PRICE_ESSENTIAL=pri_essential_price_id_here   # $17
NEXT_PUBLIC_PADDLE_PRICE_PRO=pri_pro_price_id_here               # $27
NEXT_PUBLIC_PADDLE_PRICE_ADVANCED=pri_advanced_price_id_here     # $47
NEXT_PUBLIC_PADDLE_PRICE_COMPLETE=pri_complete_price_id_here     # $97

# "sandbox" for testing, "production" for live payments
NEXT_PUBLIC_PADDLE_ENV=sandbox
