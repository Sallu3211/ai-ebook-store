# Paddle Billing Configuration
# Get these from your Paddle dashboard at paddle.com

# Your Paddle client-side token (Developer Tools > Authentication)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here

# Price ID for the product (Catalog > Prices in Paddle dashboard)
# AI Lead Generation Strategy — $17
NEXT_PUBLIC_PADDLE_PRICE_ID=pri_your_price_id_here

# "sandbox" for testing, "production" for live payments
NEXT_PUBLIC_PADDLE_ENV=sandbox
